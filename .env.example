PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bluegame?schema=public

# Keycloak/JWT verification
KEYCLOAK_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\\nYOUR_KEY_HERE\\n-----END PUBLIC KEY-----
KEYCLOAK_ISSUER=https://your-keycloak/realms/your-realm
KEYCLOAK_AUDIENCE=account
KEYCLOAK_CLIENT_ID=your-client-id

# App license defaults (used by seed / fallback)
LICENSE_MAX_USERS=1

# Signed license code verification (public key only in backend)
LICENSE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\\nYOUR_LICENSE_PUBLIC_KEY_HERE\\n-----END PUBLIC KEY-----
LICENSE_EXPECTED_ISSUER=bluegame-licensing
LICENSE_EXPECTED_AUDIENCE=bluegame-backend
LICENSE_TENANT_CODE=client-a

# Only for your private issuing machine (do NOT put private key in backend server)
LICENSE_PRIVATE_KEY_PATH=license/private.pem

# HTTPS cert files (relative to backend/)
HTTPS_KEY_PATH=certs/server.key
HTTPS_CERT_PATH=certs/server.crt
